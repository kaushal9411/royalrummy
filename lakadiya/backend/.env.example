NODE_ENV=development
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lakadiya
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin
ADMIN_SECRET=admin_panel_secret_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Razorpay — key_id goes into credentials table via admin API; key_secret stays here
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Credentials encryption (AES-256) — must be exactly 32 chars
CREDENTIALS_ENCRYPTION_KEY=change_me_to_32_chars_exactly!!!

# Email — Gmail SMTP (use App Password, not account password)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Firebase (already in firebase.js — keep them there, not here)
