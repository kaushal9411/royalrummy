<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup & data-transfer control.
  Lakadiya is a real-money financial app — ALL data excluded from cloud backup
  and device-to-device transfer to prevent exposure of:
    • Auth tokens (Hive box)
    • Wallet balances
    • KYC documents path references
    • Razorpay session state
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude everything from Google Drive backup -->
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude everything from device-to-device transfer (e.g. Quick Switch) -->
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
