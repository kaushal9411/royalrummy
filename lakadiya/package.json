{
  "name": "lakadiya-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all":  "npm install --prefix backend && npm install --prefix admin",
    "migrate":      "npm run migrate --prefix backend",
    "seed":         "node backend/src/database/seed.js",
    "dev:backend":  "npm run dev --prefix backend",
    "dev:admin":    "npm run dev --prefix admin",
    "dev":          "concurrently --names \"BACKEND,ADMIN\" --prefix-colors \"green,cyan\" \"npm run dev:backend\" \"npm run dev:admin\"",
    "start:backend":"npm start --prefix backend",
    "start:admin":  "npm start --prefix admin"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
