# =============================================================================
# RummyRoyale Backend — Environment Variables
# Copy to .env and fill in values
# =============================================================================

NODE_ENV=development
LOG_LEVEL=info

# ── Service Ports ─────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
GAME_SERVICE_PORT=3002
WALLET_SERVICE_PORT=3003
MATCHMAKING_SERVICE_PORT=3004
TOURNAMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
BOT_SERVICE_PORT=3007

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rummy_user:your_password@localhost:5432/rummyroyale
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_TLS=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_256_bit_jwt_secret_here
JWT_REFRESH_SECRET=your_256_bit_refresh_secret_here

# ── Game Engine ───────────────────────────────────────────────────────────────
# Must be exactly 32 characters for AES-256
GAME_HAND_ENCRYPTION_KEY=your32charencryptionkeygoeshere!

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3100,https://admin.rummyroyale.com

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=rummyroyale-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@rummyroyale-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── SMS (MSG91 / Twilio) ──────────────────────────────────────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_otp_template_id

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_SES_FROM=noreply@rummyroyale.com

# ── S3 (Asset Storage) ────────────────────────────────────────────────────────
AWS_S3_BUCKET=rummy-assets
AWS_S3_REGION=ap-south-1
CDN_BASE_URL=https://cdn.rummyroyale.com

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_BOT_AUTOFILL=true
BOT_FILL_WAIT_SECONDS=30
MAX_BOT_RATIO=0.6
SIGNUP_BONUS=50

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Wallet Limits ─────────────────────────────────────────────────────────────
MIN_WITHDRAWAL_AMOUNT=100
MAX_DAILY_WITHDRAWAL=100000
MAX_DAILY_DEPOSIT=100000
PLATFORM_RAKE_PERCENT=10

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
