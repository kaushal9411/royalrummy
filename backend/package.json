{
  "name": "rummyroyale-backend",
  "version": "1.0.0",
  "private": true,
  "description": "RummyRoyale backend - Express.js microservices",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:game\" \"npm run dev:wallet\" \"npm run dev:matchmaking\"",
    "dev:api": "nodemon apps/api-gateway/src/index.js",
    "dev:game": "nodemon apps/game-service/src/index.js",
    "dev:wallet": "nodemon apps/wallet-service/src/index.js",
    "dev:matchmaking": "nodemon apps/matchmaking-service/src/index.js",
    "dev:tournament": "nodemon apps/tournament-service/src/index.js",
    "dev:notification": "nodemon apps/notification-service/src/index.js",
    "dev:bot": "nodemon apps/bot-service/src/index.js",
    "start:api": "node apps/api-gateway/src/index.js",
    "start:game": "node apps/game-service/src/index.js",
    "start:wallet": "node apps/wallet-service/src/index.js",
    "migrate": "node scripts/db/migrate.js",
    "seed": "node scripts/seed/seed.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "firebase-admin": "^12.0.0",
    "razorpay": "^2.9.2",
    "nodemailer": "^6.9.8",
    "twilio": "^4.20.0",
    "uuid": "^9.0.1",
    "dayjs": "^1.11.10",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "crypto": "^1.0.1",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1503.0",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0"
  }
}
