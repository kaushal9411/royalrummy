# ─── Copy this file to .env and fill in values ────────────────────────────────
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=rummy_user
DB_PASSWORD=rummy_dev_pass
DB_NAME=rummyroyale

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=rummy_redis_pass

# ─── JWT ──────────────────────────────────────────────────────────────────────
# MUST be at least 32 chars in production — rotate every 30 days
JWT_SECRET=dev_jwt_secret_change_in_prod_min_32_chars
JWT_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=2592000

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
# MSG91_API_KEY=          # Uncomment for production SMS
# MSG91_SENDER_ID=RUMMY

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=rummyroyale
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@rummyroyale.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=rummy-assets
AWS_SES_FROM=noreply@rummyroyale.com

# ─── Service URLs (for API Gateway) ───────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
GAME_SERVICE_URL=http://localhost:3002
WALLET_SERVICE_URL=http://localhost:3003
MATCHMAKING_SERVICE_URL=http://localhost:3004
TOURNAMENT_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_BOT_AUTOFILL=true
MIN_WAIT_BEFORE_BOT_SECS=30
MAX_BOT_RATIO=0.6

# ─── Wallet Limits ────────────────────────────────────────────────────────────
MIN_WITHDRAWAL_INR=100
MAX_DAILY_WITHDRAWAL_INR=100000
MAX_DEPOSIT_INR=100000

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
